---
interface Props {
  activeTab?: 'posts' | 'projects' | 'about';
}
const { activeTab = 'posts' } = Astro.props;
---

<div class="mb-10 animate-in fade-in slide-in-from-top-6 duration-1000 ease-out fill-mode-both">
  
  {/* PROFILE CARD */}
  <div class="relative border-[1.5px] border-white/20 bg-[#0C0C0C] shadow-[8px_8px_0px_0px_rgba(213,51,139,0.6)] mb-8 transition-all duration-300 hover:shadow-[10px_10px_0px_0px_rgba(213,51,139,0.8)] hover:-translate-y-1 hover:-translate-x-1 group">
    
    {/* Identity Section */}
    <div class="flex flex-col sm:flex-row items-start gap-6 p-6 sm:p-8 border-b-[1.5px] border-white/10 bg-gradient-to-br from-[#111111] to-[#0A0A0A]">
      <div class="shrink-0 w-20 h-20 sm:w-24 sm:h-24 bg-[#0A0A0A] border-[1.5px] border-white/20 shadow-[4px_4px_0_#d5338b] flex items-center justify-center transition-transform duration-500 group-hover:rotate-[-2deg] group-hover:scale-105">
        <span class="font-mono font-black text-2xl sm:text-3xl text-[#F5F5F0] tracking-tighter">KE</span>
      </div>
      
      <div class="flex-1 pt-1 w-full">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-[#F5F5F0] tracking-tight leading-none mb-2">
          Kamerr Ezz
        </h1>
        <p class="font-mono text-[10px] sm:text-[11px] text-zinc-400 mb-4 tracking-[0.2em] uppercase flex flex-wrap items-center gap-2">
          Fullstack Dev <span class="text-[#d5338b] font-bold">/</span> Educator <span class="text-[#d5338b] font-bold">/</span> Builder
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-[9px] sm:text-[10px] font-bold tracking-[0.15em] uppercase text-zinc-300 bg-white/5 border border-white/10 px-2.5 py-1">TypeScript</span>
          <span class="font-mono text-[9px] sm:text-[10px] font-bold tracking-[0.15em] uppercase text-zinc-300 bg-white/5 border border-white/10 px-2.5 py-1">Next.js</span>
          <span class="font-mono text-[9px] sm:text-[10px] font-bold tracking-[0.15em] uppercase text-zinc-300 bg-white/5 border border-white/10 px-2.5 py-1">Node.js</span>
          <span class="font-mono text-[9px] sm:text-[10px] font-bold tracking-[0.15em] uppercase text-[#0A0A0A] bg-[#FAFF00] border border-[#FAFF00] px-2.5 py-1 shadow-[2px_2px_0_rgba(255,255,255,0.2)] ml-auto sm:ml-0 relative overflow-hidden group/badge">
            <span class="relative z-10">Open to work</span>
            <div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover/badge:translate-x-[100%] transition-transform duration-700"></div>
          </span>
        </div>
      </div>
    </div>

    {/* Bio Section */}
    <div class="p-6 sm:p-8 border-b-[1.5px] border-white/10 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNikiLz48L3N2Zz4=')]">
      <p class="text-sm sm:text-base leading-relaxed text-zinc-300 font-light border-l-2 border-[#d5338b] pl-4">
        "Aprendiendo mientras construyo proyectos digitales reales — documentando el proceso para enseñar cómo funcionan de verdad."
      </p>
    </div>

    {/* Metrics / Stats */}
    <div class="grid grid-cols-2 sm:flex sm:divide-x-[1.5px] divide-y-[1.5px] sm:divide-y-0 divide-white/10 border-b-[1.5px] border-white/10 bg-[#0A0A0A]/50">
      <div class="flex-1 flex flex-col items-center justify-center p-5 gap-1.5 hover:bg-white/5 transition-colors group/stat">
        <span class="font-mono text-2xl sm:text-3xl font-black text-[#F5F5F0] leading-none group-hover/stat:text-[#d5338b] transition-colors">4+</span>
        <span class="font-mono text-[9px] sm:text-[10px] text-zinc-500 uppercase tracking-[0.2em]">años exp</span>
      </div>
      <div class="flex-1 flex flex-col items-center justify-center p-5 gap-1.5 hover:bg-white/5 transition-colors group/stat border-l-[1.5px] sm:border-l-0 border-white/10">
        <span class="font-mono text-2xl sm:text-3xl font-black text-[#F5F5F0] leading-none group-hover/stat:text-[#d5338b] transition-colors">500+</span>
        <span class="font-mono text-[9px] sm:text-[10px] text-zinc-500 uppercase tracking-[0.2em]">estudiantes</span>
      </div>
      <div class="flex-1 flex flex-col items-center justify-center p-5 gap-1.5 hover:bg-white/5 transition-colors group/stat border-t-[1.5px] sm:border-t-0 border-white/10">
        <span class="font-mono text-2xl sm:text-3xl font-black text-[#F5F5F0] leading-none group-hover/stat:text-[#d5338b] transition-colors">90%</span>
        <span class="font-mono text-[9px] sm:text-[10px] text-zinc-500 uppercase tracking-[0.2em]">TypeScript</span>
      </div>
      <div class="flex-1 flex flex-col items-center justify-center p-5 gap-1.5 hover:bg-white/5 transition-colors group/stat border-l-[1.5px] border-white/10">
        <span class="font-mono text-2xl sm:text-3xl font-black text-[#F5F5F0] leading-none group-hover/stat:text-[#d5338b] transition-colors">3</span>
        <span class="font-mono text-[9px] sm:text-[10px] text-zinc-500 uppercase tracking-[0.2em]">productos</span>
      </div>
    </div>

    {/* Connect / Socials */}
    <div class="flex divide-x-[1.5px] divide-white/10 bg-[#111111]">
      <a href="https://github.com/KamerrEzz" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 py-4 font-mono text-[10px] sm:text-[11px] font-bold tracking-[0.15em] uppercase text-zinc-400 hover:text-white hover:bg-white/5 transition-all group/link">
        <svg class="w-4 h-4 group-hover/link:text-[#d5338b] transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="https://linkedin.com/in/KamerrEzz" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 py-4 font-mono text-[10px] sm:text-[11px] font-bold tracking-[0.15em] uppercase text-zinc-400 hover:text-white hover:bg-white/5 transition-all group/link">
        <svg class="w-4 h-4 group-hover/link:text-[#d5338b] transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <a href="https://zeew.space" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 py-4 font-mono text-[10px] sm:text-[11px] font-bold tracking-[0.15em] uppercase text-[#d5338b] hover:bg-[#d5338b] hover:text-white transition-all">
        zeew.space ↗
      </a>
    </div>
  </div>

  {/* TABS NAVIGATION */}
  <nav class="flex border-[1.5px] border-white/20 bg-[#0A0A0A] shadow-[4px_4px_0_rgba(255,255,255,0.05)] overflow-hidden relative" aria-label="Navegación principal">
    <a href="/" class={`flex-1 text-center py-4 font-mono text-[10px] sm:text-[11px] font-bold tracking-[0.2em] uppercase transition-all duration-300 relative z-10 ${activeTab === 'posts' ? 'text-[#0A0A0A]' : 'text-zinc-500 hover:text-zinc-200 hover:bg-white/5'} border-r-[1.5px] border-white/10 last:border-r-0 group`}>
      {activeTab === 'posts' && <div class="absolute inset-0 bg-white z-[-1] animate-in slide-in-from-left-full"></div>}
      Posts
      {activeTab === 'posts' && <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#d5338b]"></div>}
    </a>
    <a href="/projects" class={`flex-1 text-center py-4 font-mono text-[10px] sm:text-[11px] font-bold tracking-[0.2em] uppercase transition-all duration-300 relative z-10 ${activeTab === 'projects' ? 'text-[#0A0A0A]' : 'text-zinc-500 hover:text-zinc-200 hover:bg-white/5'} border-r-[1.5px] border-white/10 last:border-r-0 group`}>
      {activeTab === 'projects' && <div class="absolute inset-0 bg-white z-[-1] animate-in fade-in"></div>}
      Proyectos
      {activeTab === 'projects' && <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#d5338b]"></div>}
    </a>
    <a href="/about" class={`flex-1 text-center py-4 font-mono text-[10px] sm:text-[11px] font-bold tracking-[0.2em] uppercase transition-all duration-300 relative z-10 ${activeTab === 'about' ? 'text-[#0A0A0A]' : 'text-zinc-500 hover:text-zinc-200 hover:bg-white/5'}`}>
      {activeTab === 'about' && <div class="absolute inset-0 bg-white z-[-1] animate-in slide-in-from-right-full"></div>}
      Sobre mí
      {activeTab === 'about' && <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#d5338b]"></div>}
    </a>
  </nav>
</div>
