---
interface Friend {
  name: string;
  url: string;
  logo: string;
}

const friends: Friend[] = [
  { name: "Amigo 1", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Sponsor 1", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Amigo 2", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Amigo 3", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Sponsor 2", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Amigo 4", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Amigo 5", url: "#", logo: "https://via.placeholder.com/150" },
  { name: "Sponsor 3", url: "#", logo: "https://via.placeholder.com/150" }
];
---

<section class="flex flex-col border-t-[1.5px] border-white/10">
  <div class="px-8 py-6 border-b-[1.5px] border-white/10 bg-[#050505] relative">
    <h2 class="font-mono text-sm md:text-base font-black tracking-[0.3em] uppercase flex items-center gap-3 text-zinc-300">
      <div class="w-3 h-3 bg-[#FAFF00] shadow-[0_0_8px_rgba(250,255,0,0.5)] animate-pulse"></div>
      Sponsors & Amigos
    </h2>
    <p class="text-zinc-500 font-light mt-3 max-w-xl text-sm leading-relaxed">
      Gente increíble y proyectos brutales que me han apoyado sinceramente en el camino.
    </p>
  </div>
  
  {/* GRID DENSO TIPO "MURO" PARA LOGOS/FOTOS */}
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 divide-x-[1.5px] divide-y-[1.5px] border-b-[1.5px] border-l-[1.5px] -ml-[1.5px] divide-white/10 border-white/10 bg-[#0A0A0A]">
    {friends.map((friend) => (
      <a href={friend.url} target="_blank" rel="noopener noreferrer" class="aspect-square flex flex-col items-center justify-center p-4 group hover:bg-[#111] transition-colors relative overflow-hidden">
        <div class="w-16 h-16 rounded-full border-[1.5px] border-white/20 mb-3 bg-[#1A1A1A] overflow-hidden group-hover:scale-105 group-hover:border-[#FAFF00] group-hover:shadow-[0_0_15px_rgba(250,255,0,0.2)] transition-all">
          <img 
            src={friend.logo} 
            alt={friend.name} 
            class="w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
          />
        </div>
        <span class="font-mono text-[9px] font-bold uppercase tracking-widest text-zinc-500 text-center group-hover:text-white transition-colors truncate w-full px-2">
          {friend.name}
        </span>
      </a>
    ))}
  </div>
</section>
