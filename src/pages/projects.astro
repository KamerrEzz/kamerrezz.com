---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => {
	const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
	const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
	return dateB - dateA;
});
---

<!doctype html>
<html lang="es" class="dark scroll-smooth">
	<head>
		<BaseHead
			title={`Proyectos - ${SITE_TITLE}`}
			description="Proyectos reales de Kamerr Ezz: construcción, iteración y documentación. Desde la idea hasta la ejecución, con procesos visibles."
		/>
	</head>
	
	<body class="bg-[#050505] text-[#FAFAFA] font-sans selection:bg-[#d5338b] selection:text-white" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0); background-size: 32px 32px;">
		
		<div class="max-w-[1200px] mx-auto min-h-screen border-x-[1.5px] border-white/10 bg-[#0A0A0A]/90 backdrop-blur-md flex flex-col shadow-[0_0_80px_rgba(0,0,0,0.9)]">
			
			{/* ── TOP NAV ── */}
			<nav class="flex items-stretch border-b-[1.5px] border-white/10 sticky top-0 z-50 bg-[#0A0A0A] h-14">
				<a href="/" class="flex items-center px-4 md:px-8 font-mono text-[11px] md:text-sm font-black tracking-widest uppercase text-zinc-500 transition-colors hover:text-white hover:bg-white/10 border-r-[1.5px] border-white/10 w-max shrink-0">
					<span class="w-2 h-2 bg-zinc-600 mr-2 transition-colors group-hover:bg-white"></span>
					KamerrEzz
				</a>
				<div class="flex-1 flex justify-end">
					<a href="/projects" class="hidden sm:flex items-center justify-center px-6 font-mono text-xs font-bold tracking-widest uppercase text-white bg-white/5 border-l-[1.5px] border-white/10 transition-colors">
						<span class="w-1.5 h-1.5 bg-[#d5338b] mr-2 shadow-[0_0_8px_#d5338b]"></span>
						Proyectos
					</a>
					<a href="/blog" class="hidden sm:flex items-center justify-center px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white hover:bg-white/5 border-l-[1.5px] border-white/10 transition-colors">
						Blog
					</a>
					<a href="https://github.com/KamerrEzz" target="_blank" class="flex sm:hidden lg:flex items-center justify-center px-4 md:px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-[#d5338b] hover:bg-[#d5338b]/10 border-l-[1.5px] border-white/10 transition-all">
						GitHub ↗
					</a>
				</div>
			</nav>

			{/* ── MAIN CONTENT ── */}
			<main class="flex-1 flex flex-col">
				
				{/* PAGE HEADER */}
				<header class="p-8 md:p-12 lg:p-20 border-b-[1.5px] border-white/10 relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent pointer-events-none"></div>
					
					<div class="mb-4">
						<span class="px-3 py-1 bg-white/5 border-[1.5px] border-white/10 text-white font-mono text-xs font-black uppercase tracking-widest">
							Portafolio ///
						</span>
					</div>

					<h1 class="text-5xl sm:text-7xl md:text-8xl font-black tracking-tighter text-[#FAFAFA] mb-6">
						MIS <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-400 to-[#d5338b]">PROYECTOS.</span>
					</h1>
					
					<p class="text-lg md:text-xl text-zinc-400 max-w-2xl leading-relaxed font-light">
						Desde la arquitectura inicial hasta el código en producción. Productos digitales desarrollados solucionando problemas reales del mundo del software.
					</p>
				</header>

				{/* PROJECTS LIST */}
				<section class="flex flex-col">
					{sortedProjects.map((project, index) => {
						const getStatusText = (status?: string) => {
							if (status === 'completed') return 'Completado';
							if (status === 'active') return 'En Producción';
							if (status === 'in-progress') return 'Construyendo';
							return 'Evolucionando';
						};

						const statusColor = project.data.status === 'completed' || project.data.status === 'active' 
							? 'text-green-400 border-green-400/30 bg-green-400/10'
							: 'text-[#FAFF00] border-[#FAFF00]/30 bg-[#FAFF00]/10';

						return (
							<article class="grid grid-cols-1 md:grid-cols-12 border-b-[1.5px] border-white/10 group">
								{/* Left Meta Information */}
								<div class="md:col-span-5 p-8 border-b-[1.5px] md:border-b-0 md:border-r-[1.5px] border-white/10 flex flex-col justify-between group-hover:bg-white/[0.02] transition-colors relative">
									<div class="absolute top-4 left-4 font-mono text-6xl md:text-8xl font-black text-white/5 -z-10 group-hover:text-white/10 transition-colors">
										{String(index + 1).padStart(2, '0')}
									</div>
									
									<div class="mt-4 mb-10">
										<div class="flex items-center gap-3 mb-4">
											<span class={`px-2 py-1 flex items-center gap-2 border-[1.5px] font-mono text-[10px] uppercase font-bold tracking-widest ${statusColor}`}>
												<span class="w-1.5 h-1.5 bg-current rounded-full animate-pulse"></span>
												{getStatusText(project.data.status)}
											</span>
										</div>
										
										<h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white mb-4">
											{project.data.title}
										</h2>
										
										<p class="text-sm text-zinc-400 leading-relaxed font-light">
											{project.data.description}
										</p>
									</div>

									{/* Tech flow */}
									<div class="flex flex-wrap gap-2 mt-auto">
										{(project.data.technologies || []).map(tech => (
											<span class="px-2 py-1 border-[1.5px] border-white/10 font-mono text-[10px] uppercase tracking-widest text-zinc-500 bg-white/5">
												{tech}
											</span>
										))}
									</div>
								</div>

								{/* Right Interaction / Preview */}
								<div class="md:col-span-7 bg-[#111111] p-8 md:p-12 relative flex items-center justify-center overflow-hidden">
									<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white/[0.03] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
									
									<a href={`/projects/${project.id}/`} class="relative block w-full aspect-video border-[1.5px] border-white/20 bg-[#0A0A0A] shadow-[8px_8px_0_rgba(255,255,255,0.05)] group-hover:shadow-[12px_12px_0_#d5338b] group-hover:-translate-y-1 group-hover:-translate-x-1 transition-all duration-300 flex flex-col focus:outline-none">
										{/* Toolbar */}
										<div class="h-6 w-full border-b-[1.5px] border-white/10 flex items-center justify-between px-3 bg-white/5 shrink-0">
											<div class="flex items-center gap-1.5">
												<div class="w-2 h-2 rounded-full border-[1.5px] border-zinc-500 group-hover:border-[#d5338b] transition-colors"></div>
												<div class="w-2 h-2 rounded-full border-[1.5px] border-zinc-600"></div>
												<div class="w-2 h-2 rounded-full border-[1.5px] border-zinc-600"></div>
											</div>
											<span class="font-mono text-[9px] uppercase tracking-widest text-zinc-600 group-hover:text-[#d5338b] transition-colors">/{project.id}</span>
										</div>
										
										{/* Content Area */}
										<div class="flex-1 flex flex-col items-center justify-center relative z-10 p-6 text-center group-hover:bg-[#d5338b]/5 transition-colors">
											<span class="font-mono text-[10px] font-bold tracking-[0.3em] uppercase text-zinc-400 group-hover:text-white transition-colors mb-4">
												Ver Detalles
											</span>
											<div class="w-12 h-12 border-[1.5px] border-zinc-500 rounded-full flex items-center justify-center group-hover:bg-[#d5338b] group-hover:border-[#d5338b] group-hover:scale-110 transition-all">
												<svg class="w-5 h-5 text-zinc-500 group-hover:text-white transition-colors group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
												</svg>
											</div>
										</div>
									</a>
								</div>
							</article>
						);
					})}
				</section>
			</main>

			{/* ── FOOTER ── */}
			<footer class="border-t-[1.5px] border-white/10 bg-[#111111]">
				<div class="p-8 md:p-16 flex flex-col items-center justify-center text-center border-b-[1.5px] border-white/10 group">
					<span class="font-mono text-xs text-zinc-500 uppercase tracking-[0.3em] mb-4">¿Tienes una idea en mente?</span>
					<a href="https://zeew.space" target="_blank" class="text-4xl sm:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-zinc-600 hover:scale-105 transition-transform">
						HABLEMOS.
					</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 divide-y-[1.5px] md:divide-y-0 md:divide-x-[1.5px] divide-white/10 text-center">
					<div class="p-6 flex items-center justify-center gap-3">
						<span class="w-2.5 h-2.5 bg-green-500 shadow-[0_0_12px_#22c55e]"></span>
						<span class="font-mono text-[10px] sm:text-xs font-bold tracking-widest uppercase text-white">Disponible</span>
					</div>
					<div class="p-6 flex flex-wrap gap-4 items-center justify-center">
						<a href="https://github.com/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">GitHub</a>
						<span class="text-zinc-600">/</span>
						<a href="https://linkedin.com/in/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">LinkedIn</a>
					</div>
					<div class="p-6 flex items-center justify-center">
						<span class="font-mono text-[10px] text-zinc-500 tracking-widest uppercase">© {new Date().getFullYear()} KamerrEzz</span>
					</div>
				</div>
			</footer>
			
		</div>
	</body>
</html>