---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="es" class="dark scroll-smooth">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	
	<body class="bg-[#050505] text-[#FAFAFA] font-sans selection:bg-[#d5338b] selection:text-white" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0); background-size: 32px 32px;">
		
		<div class="max-w-[1200px] mx-auto min-h-screen border-x-[1.5px] border-white/10 bg-[#0A0A0A]/90 backdrop-blur-md flex flex-col shadow-[0_0_80px_rgba(0,0,0,0.9)]">
			
			{/* ── TOP NAV ── */}
			<nav class="flex items-stretch border-b-[1.5px] border-white/10 sticky top-0 z-50 bg-[#0A0A0A] h-14">
				<a href="/" class="flex items-center px-4 md:px-8 font-mono text-[11px] md:text-sm font-black tracking-widest uppercase text-zinc-500 transition-colors hover:text-white hover:bg-white/10 border-r-[1.5px] border-white/10 w-max shrink-0 group">
					<span class="w-2 h-2 bg-zinc-600 mr-2 transition-colors group-hover:bg-white"></span>
					KamerrEzz
				</a>
				<div class="flex-1 flex justify-end">
					<a href="/projects" class="hidden sm:flex items-center justify-center px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white hover:bg-white/5 border-l-[1.5px] border-white/10 transition-colors">
						Proyectos
					</a>
					<a href="/blog" class="hidden sm:flex items-center justify-center px-6 font-mono text-xs font-bold tracking-widest uppercase text-white bg-white/5 border-l-[1.5px] border-white/10 transition-colors">
						<span class="w-1.5 h-1.5 bg-[#d5338b] mr-2 shadow-[0_0_8px_#d5338b]"></span>
						Blog
					</a>
					<a href="https://github.com/KamerrEzz" target="_blank" class="flex sm:hidden lg:flex items-center justify-center px-4 md:px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-[#d5338b] hover:bg-[#d5338b]/10 border-l-[1.5px] border-white/10 transition-all">
						GitHub ↗
					</a>
				</div>
			</nav>

			{/* ── MAIN CONTENT ── */}
			<main class="flex-1 flex flex-col">
				
				{/* PAGE HEADER */}
				<header class="p-8 md:p-12 lg:p-20 border-b-[1.5px] border-white/10 relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent pointer-events-none"></div>
					
					<div class="mb-4">
						<span class="px-3 py-1 border-[1.5px] border-[#d5338b] text-[#d5338b] font-mono text-xs font-black uppercase tracking-widest bg-[#d5338b]/10">
							Bitácora
						</span>
					</div>

					<h1 class="text-5xl sm:text-7xl md:text-8xl font-black tracking-tighter text-[#FAFAFA] mb-6">
						EL <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-400 to-[#d5338b]">BLOG.</span>
					</h1>
					
					<p class="text-lg md:text-xl text-zinc-400 max-w-2xl leading-relaxed font-light">
						Notas, reflexiones y tutoriales sobre desarrollo de software, diseño de sistemas e ingeniería de productos.
					</p>
				</header>

				{/* BLOG POSTS GRID */}
				<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 divide-y-[1.5px] md:divide-y-0 md:divide-x-[1.5px] divide-white/10 border-b-[1.5px] border-white/10">
					{posts.map((post, index) => {
						// Make the first post span full rows/cols on small/medium if needed,
                        // or just keep a highly structured grid.
						return (
							<a 
								href={`/blog/${post.id}/`}
								class="group flex flex-col bg-[#0A0A0A] hover:bg-white/[0.03] transition-colors border-b-[1.5px] border-white/10 last:border-b-0 md:border-b-0 pb-[1.5px] md:pb-0"
							>
								{/* Thumbnail Section */}
								<div class="aspect-video w-full border-b-[1.5px] border-white/10 bg-[#111111] overflow-hidden relative">
									<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
									{post.data.heroImage ? (
										<Image 
											width={720} 
											height={360} 
											src={post.data.heroImage} 
											alt={post.data.title}
											class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 group-hover:rotate-1"
										/>
									) : (
										<div class="w-full h-full flex flex-col items-center justify-center p-6 text-center">
                                            {/* Fallback image placeholder */}
                                            <span class="font-mono text-zinc-600 font-bold uppercase tracking-widest text-xs">Sin Imagen</span>
                                            <div class="w-16 h-[1.5px] bg-zinc-800 mt-2"></div>
                                        </div>
									)}
								</div>

								{/* Content Section */}
								<div class="p-6 md:p-8 flex flex-col flex-1 relative">
                                    <div class="absolute top-0 right-0 p-4 opacity-0 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300">
                                        <div class="w-8 h-8 rounded-full bg-[#d5338b] flex items-center justify-center text-white border-[1.5px] border-white/20">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                                            </svg>
                                        </div>
                                    </div>

									<div class="font-mono text-[10px] text-zinc-500 uppercase tracking-widest mb-4 flex items-center gap-2">
										<FormattedDate date={post.data.pubDate} />
										<span class="w-1 h-1 bg-zinc-600 rounded-full"></span>
										<span class="text-[#d5338b] font-bold">Reseña</span>
									</div>
									
									<h2 class="text-xl sm:text-2xl font-bold text-white mb-3 tracking-tight group-hover:text-[#FAFF00] transition-colors leading-tight line-clamp-2">
										{post.data.title}
									</h2>
									
									<p class="text-sm text-zinc-400 font-light leading-relaxed line-clamp-3 mb-6">
										{post.data.description}
									</p>

                                    <div class="mt-auto pt-4 border-t-[1.5px] border-white/5 flex items-center justify-between">
                                        <span class="font-mono text-[10px] uppercase tracking-[0.2em] font-bold text-zinc-500 group-hover:text-white transition-colors">
                                            Leer Artículo
                                        </span>
                                    </div>
								</div>
							</a>
						);
					})}
				</section>
			</main>

			{/* ── FOOTER ── */}
			<footer class="bg-[#111111]">
				<div class="p-8 md:p-16 flex flex-col items-center justify-center text-center border-b-[1.5px] border-white/10 group">
					<span class="font-mono text-xs text-zinc-500 uppercase tracking-[0.3em] mb-4">¿Tienes una idea en mente?</span>
					<a href="https://zeew.space" target="_blank" class="text-4xl sm:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-zinc-600 hover:scale-105 transition-transform">
						HABLEMOS.
					</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 divide-y-[1.5px] md:divide-y-0 md:divide-x-[1.5px] divide-white/10 text-center">
					<div class="p-6 flex items-center justify-center gap-3">
						<span class="w-2.5 h-2.5 bg-green-500 shadow-[0_0_12px_#22c55e]"></span>
						<span class="font-mono text-[10px] sm:text-xs font-bold tracking-widest uppercase text-white">Disponible</span>
					</div>
					<div class="p-6 flex flex-wrap gap-4 items-center justify-center">
						<a href="https://github.com/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">GitHub</a>
						<span class="text-zinc-600">/</span>
						<a href="https://linkedin.com/in/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">LinkedIn</a>
					</div>
					<div class="p-6 flex items-center justify-center">
						<span class="font-mono text-[10px] text-zinc-500 tracking-widest uppercase">© {new Date().getFullYear()} KamerrEzz</span>
					</div>
				</div>
			</footer>
			
		</div>
	</body>
</html>
