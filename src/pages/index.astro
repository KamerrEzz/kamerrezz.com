---
import BaseHead from "../components/BaseHead.astro";
// import SponsorsGrid from "../components/SponsorsGrid.astro"; // <- DESCOMENTAR CUANDO TENGAS PERMISOS
import {
  SITE_AUTHOR,
  SITE_DESCRIPTION,
  SITE_TITLE,
  SITE_URL,
  TWITTER_HANDLE,
} from "../consts";
import { getCollection } from "astro:content";

// Data fetching
const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = allPosts.slice(0, 3);

// Fetch projects if collection exists
let allProjects = [];
try {
  allProjects = (await getCollection("projects")).sort(
    (a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0)
  );
} catch (e) {
  // collection might be empty or missing
}
const featuredProjects = allProjects.filter(p => p.data.featured).slice(0, 2);
if (featuredProjects.length === 0 && allProjects.length > 0) {
  featuredProjects.push(...allProjects.slice(0, 2));
}

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE_AUTHOR,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  sameAs: [
    `https://twitter.com/${TWITTER_HANDLE}`,
    "https://github.com/KamerrEzz",
  ],
  jobTitle: "Full-stack developer & builder-educator",
  knowsAbout: [
    "full-stack development",
    "product building",
    "practical education",
    "entrepreneurship",
  ],
};

const MONTHS_ES = [
  "Ene","Feb","Mar","Abr","May","Jun",
  "Jul","Ago","Sep","Oct","Nov","Dic"
];
---

<!doctype html>
<html lang="es" class="dark scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>

  <body class="bg-[#050505] text-[#FAFAFA] font-sans selection:bg-[#d5338b] selection:text-white" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0); background-size: 32px 32px;">
    
    <div class="max-w-[1200px] mx-auto min-h-screen border-x-[1.5px] border-white/10 bg-[#0A0A0A]/90 backdrop-blur-md flex flex-col shadow-[0_0_80px_rgba(0,0,0,0.9)]">
      
      {/* ── TOP NAV ── */}
      <nav class="flex items-stretch border-b-[1.5px] border-white/10 sticky top-0 z-50 bg-[#0A0A0A] h-14">
        <a href="/" class="flex items-center px-4 md:px-8 font-mono text-[11px] md:text-sm font-black tracking-widest uppercase transition-colors hover:bg-white/10 border-r-[1.5px] border-white/10 w-max shrink-0">
          <span class="w-2 h-2 bg-[#d5338b] mr-2 shadow-[0_0_8px_#d5338b]"></span>
          KamerrEzz
        </a>
        <div class="flex-1 flex justify-end">
          <a href="/projects" class="hidden sm:flex items-center justify-center px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white hover:bg-white/5 border-l-[1.5px] border-white/10 transition-colors">
            Proyectos
          </a>
          <a href="/blog" class="hidden sm:flex items-center justify-center px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white hover:bg-white/5 border-l-[1.5px] border-white/10 transition-colors">
            Blog
          </a>
          <a href="https://github.com/KamerrEzz" target="_blank" class="flex sm:hidden lg:flex items-center justify-center px-4 md:px-6 font-mono text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-[#d5338b] hover:bg-[#d5338b]/10 border-l-[1.5px] border-white/10 transition-all">
            GitHub ↗
          </a>
        </div>
      </nav>

      {/* ── MAIN CONTENT ── */}
      <main class="flex-1 flex flex-col">
        
        {/* HERO SECTION */}
        <section class="grid grid-cols-1 lg:grid-cols-12 border-b-[1.5px] border-white/10 leading-none">
          
          {/* Main Hero Copy - spanning 8 cols on desktop */}
          <div class="lg:col-span-8 p-8 md:p-12 lg:p-16 xl:p-20 flex flex-col justify-center border-b-[1.5px] lg:border-b-0 lg:border-r-[1.5px] border-white/10 relative group">
            <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
            
            <div class="mb-6 flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-[#FAFF00] text-black font-mono text-xs font-black uppercase tracking-widest shadow-[3px_3px_0_rgba(255,255,255,0.2)]">Open to work</span>
              <span class="px-3 py-1 border-[1.5px] border-[#d5338b] text-[#d5338b] font-mono text-xs font-bold uppercase tracking-widest bg-[#d5338b]/10">Base: México</span>
            </div>

            <h1 class="text-5xl sm:text-6xl md:text-7xl xl:text-[5.5rem] font-black tracking-tighter text-[#FAFAFA] mb-6 leading-none">
              TE ENSEÑO LO QUE APRENDO MIENTRAS LO <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-400 to-[#d5338b]">CONSTRUYO.</span>
            </h1>
            
            <p class="text-lg md:text-xl xl:text-2xl text-zinc-400 max-w-2xl leading-relaxed font-light mb-10">
              Soy KamerrEzz — dev fullstack, emprendedor y un tipo random en internet que está creando su comunidad, sus productos y compartiendo todo el proceso.
            </p>

            <div class="flex flex-wrap gap-4 mt-auto">
              <a href="https://www.linkedin.com/in/kamerrezz/" target="_blank" class="px-6 py-4 bg-[#d5338b] text-white font-mono text-sm font-black uppercase tracking-widest shadow-[6px_6px_0_0_#FAFAFA] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0_0_#FAFAFA] transition-all focus:outline-none">
                Conectemos ↗
              </a>
              <a href="#proyectos" class="px-6 py-4 bg-[#0A0A0A] border-[1.5px] border-white/20 text-zinc-300 font-mono text-sm font-bold uppercase tracking-widest hover:bg-white/10 transition-all focus:outline-none">
                Ver Proyectos ↓
              </a>
            </div>
          </div>

          {/* Details / Stats Grid Sidebar - spanning 4 cols */}
          <div class="lg:col-span-4 flex flex-col divide-y-[1.5px] divide-white/10 overflow-hidden">
            
            {/* Avatar block */}
            <div class="p-8 flex items-center justify-center bg-white/[0.01] relative overflow-hidden group">
              <div class="w-32 h-32 md:w-40 md:h-40 border-[1.5px] border-white/20 bg-[#111] flex items-center justify-center z-10 shadow-[8px_8px_0_#d5338b] group-hover:rotate-6 group-hover:scale-110 transition-all duration-500">
                <span class="text-5xl font-black font-mono tracking-tighter text-white mix-blend-difference">KE</span>
              </div>
              {/* Back geometric shapes */}
              <div class="absolute w-40 h-40 border border-white/10 rotate-12 z-0 group-hover:-rotate-12 transition-transform duration-700"></div>
            </div>

            {/* Stat Row 1 */}
            <div class="flex divide-x-[1.5px] divide-white/10">
              <div class="flex-1 p-6 flex flex-col hover:bg-[#d5338b]/10 transition-colors">
                <span class="font-mono text-xs text-zinc-500 uppercase tracking-[0.2em] mb-1">Experiencia</span>
                <span class="text-3xl font-black font-mono">4+ <span class="text-[#d5338b]">Años</span></span>
              </div>
              <div class="flex-1 p-6 flex flex-col hover:bg-[#d5338b]/10 transition-colors">
                <span class="font-mono text-xs text-zinc-500 uppercase tracking-[0.2em] mb-1">Stack</span>
                <span class="text-3xl font-black font-mono">TS <span class="text-[#d5338b]">/ Node</span></span>
              </div>
            </div>

            {/* Stat Row 2 */}
            <div class="flex divide-x-[1.5px] divide-white/10">
              <div class="flex-1 p-6 flex flex-col hover:bg-[rgba(250,255,0,0.1)] transition-colors">
                <span class="font-mono text-xs text-zinc-500 uppercase tracking-[0.2em] mb-1">Impacto</span>
                <span class="text-3xl font-black font-mono">500+ <span class="text-[#FAFF00] text-xl">Alumnos</span></span>
              </div>
            </div>
            
            {/* Tech Stack Banner */}
            <div class="p-6 bg-[#111] overflow-hidden whitespace-nowrap relative flex items-center group">
              <div class="absolute inset-y-0 left-0 w-8 bg-gradient-to-r from-[#111] to-transparent z-10"></div>
              <div class="absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-[#111] to-transparent z-10"></div>
              <div class="font-mono text-xs font-bold text-zinc-400 tracking-[0.2em] uppercase inline-flex gap-8 group-hover:-translate-x-[50%] transition-transform duration-[10000ms] ease-linear">
                <span>TypeScript</span><span>*</span>
                <span>Next.js</span><span>*</span>
                <span>Astro</span><span>*</span>
                <span>Tailwind</span><span>*</span>
                <span>Node.js</span><span>*</span>
                <span>SQL</span>
              </div>
            </div>

          </div>
        </section>

        {/* ── SOBRE MI / BIOGRAFÍA ── */}
        <section class="border-b-[1.5px] border-white/10 bg-[#080808] flex flex-col lg:flex-row">
          
          {/* Vertical Label */}
          <div class="hidden lg:flex w-16 xl:w-20 shrink-0 border-r-[1.5px] border-white/10 items-center justify-center bg-[#050505] p-4 relative">
            <span class="absolute whitespace-nowrap font-mono text-[10px] xl:text-xs -rotate-90 uppercase tracking-[0.4em] text-zinc-600 font-bold">
              Background File
            </span>
          </div>

          {/* Main Content Box */}
          <div class="flex-1 p-8 md:p-12 lg:p-16 xl:p-20 relative overflow-hidden group">
            {/* Subtle bg glow */}
            <div class="absolute -right-40 -bottom-40 w-96 h-96 bg-[#d5338b]/5 blur-[100px] rounded-full mix-blend-screen pointer-events-none"></div>

            <div class="mb-4 relative z-10">
              <span class="font-mono text-[10px] uppercase font-bold tracking-[0.4em] text-zinc-500">
                <span class="text-[#d5338b]">///</span> Sobre mí
              </span>
            </div>
            
            <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter text-white mb-10 relative z-10">
              ¿Quién es este tipo?
            </h2>

            <div class="max-w-3xl space-y-6 relative z-10 font-light text-zinc-300 text-lg md:text-xl leading-relaxed">
              <p>
                Escribí mi primera línea de código a los 7 años haciendo plugins para servidores de Minecraft. 
                No terminé en eso — la curiosidad me llevó por desarrollo web, bots de Discord, automatización 
                y ahora productos propios con usuarios reales.
              </p>
              
              <div class="border-l-[3px] border-l-[#FAFF00] pl-6 py-4 bg-gradient-to-r from-white/[0.02] to-transparent my-8 shadow-[4px_4px_0_rgba(250,255,0,0.05)] border-[1.5px] border-white/5 border-l-[#FAFF00] group-hover:border-l-[#d5338b] group-hover:shadow-[4px_4px_0_rgba(213,51,139,0.1)] transition-colors duration-500">
                No estudié en una escuela cara. No pagué plataformas premium. Aprendí la mayoría de lo que sé 
                por mi cuenta, rompiendo cosas y leyendo documentación a las 3am. 
                <br/>
                <strong class="font-bold inline-block mt-3 text-white">El 75% de mi conocimiento es autodidacta.</strong>
              </div>

              <p>
                Hoy construyo herramientas para desarrolladores, enseño programación y lidero una comunidad donde 
                la gente aprende creando cosas reales, no siguiendo tutoriales que se olvidan al día siguiente.
              </p>
            </div>

            <div class="mt-12 relative z-10">
              <span class="inline-flex flex-wrap items-center gap-2 px-4 py-2 border-[1.5px] border-[#d5338b]/30 bg-[#d5338b]/5 font-mono text-[10px] md:text-xs tracking-widest font-bold">
                <span class="w-2 h-2 rounded-full border border-[1.5px] border-[#d5338b] bg-[#d5338b]/20"></span>
                <span class="text-zinc-300 uppercase">Ah, y estoy terminando Ingeniería en Sistemas. Desde</span>
                <span class="text-[#d5338b] uppercase">Playa del Carmen, México.</span>
              </span>
            </div>
          </div>
        </section>

        {/* PROJECTS SECTION */}
        <section id="proyectos" class="flex flex-col border-b-[1.5px] border-white/10 relative">
          <div class="px-8 py-6 border-b-[1.5px] border-white/10 bg-[#0A0A0A]/95 sticky top-14 z-40">
            <h2 class="font-mono text-sm md:text-base font-black tracking-[0.3em] uppercase flex items-center gap-3">
              <div class="w-3 h-3 bg-[#FAFAFA]"></div>
              Proyectos Destacados
            </h2>
          </div>
          
          <div class="w-full flex-col">
            {featuredProjects.length > 0 ? (
              featuredProjects.map((project, index) => (
                <div class="grid grid-cols-1 md:grid-cols-12 border-b-[1.5px] border-white/10 last:border-b-0 group">
                  
                  {/* Left Column: Number + Info */}
                  <div class="md:col-span-5 p-8 flex flex-col justify-between border-b-[1.5px] md:border-b-0 md:border-r-[1.5px] border-white/10 group-hover:bg-white/[0.02] transition-colors">
                    <div class="mb-12">
                      <span class="font-mono text-6xl md:text-8xl font-black text-white/5 absolute top-4 left-4 -z-10 group-hover:text-white/10 transition-colors">0{index + 1}</span>
                      <h3 class="text-3xl font-black tracking-tight mb-2 mt-4">{project.data.title}</h3>
                      <p class="text-zinc-400 leading-relaxed font-light mt-4">
                        {project.data.description}
                      </p>
                    </div>

                    <div class="flex flex-wrap gap-2 mt-auto">
                      {(project.data.technologies || []).slice(0, 4).map(tech => (
                        <span class="px-2 py-1 border-[1.5px] border-white/10 font-mono text-[10px] uppercase tracking-widest text-zinc-500 bg-white/5">
                          {tech}
                        </span>
                      ))}
                    </div>
                  </div>

                  {/* Right Column: Interaction / Cover placeholder */}
                  <div class="md:col-span-7 bg-[#111111] p-8 md:p-12 relative overflow-hidden flex items-center justify-center">
                    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-[#d5338b] via-transparent to-transparent group-hover:opacity-20 transition-opacity duration-500"></div>
                    
                    <a href={`/projects/${project.id}/`} class="relative block w-full aspect-video border-[1.5px] border-white/20 bg-[#0A0A0A] shadow-[8px_8px_0_rgba(255,255,255,0.05)] group-hover:shadow-[12px_12px_0_#d5338b] group-hover:-translate-y-1 group-hover:-translate-x-1 transition-all duration-300 flex flex-col overflow-hidden">
                      {/* Fake Browser Top Bar */}
                      <div class="h-6 w-full border-b-[1.5px] border-white/10 flex items-center gap-1.5 px-3 bg-white/5 shrink-0">
                        <div class="w-2 h-2 rounded-full border-[1.5px] border-zinc-600"></div>
                        <div class="w-2 h-2 rounded-full border-[1.5px] border-zinc-600"></div>
                        <div class="w-2 h-2 rounded-full border-[1.5px] border-zinc-600"></div>
                      </div>
                      
                      <div class="flex-1 flex flex-col items-center justify-center gap-3 relative z-10 p-6 text-center">
                        <span class="text-zinc-600 font-mono text-xs tracking-widest uppercase">Explorar Proyecto</span>
                        <div class="w-10 h-10 border-[1.5px] border-zinc-500 rounded-full flex items-center justify-center group-hover:bg-[#d5338b] group-hover:border-[#d5338b] group-hover:scale-110 transition-all font-bold group-hover:text-white">
                          →
                        </div>
                      </div>
                    </a>
                  </div>

                </div>
              ))
            ) : (
              <div class="p-16 text-center text-zinc-500 font-mono text-sm tracking-widest uppercase bg-[#111111]">
                [ Proyectos Cargando ]
              </div>
            )}
            
            {/* View All Projects Block */}
            <a href="/projects" class="block w-full py-8 text-center bg-[#d5338b] hover:bg-white text-white hover:text-black transition-colors font-mono font-black text-xl md:text-3xl tracking-widest uppercase border-b-[1.5px] border-white/20">
              Ver todos los proyectos ↗
            </a>
          </div>
        </section>

        {/* BLOG SECTION */}
        <section class="grid grid-cols-1 lg:grid-cols-4">
          <div class="p-8 border-b-[1.5px] lg:border-b-0 lg:border-r-[1.5px] border-white/10 bg-[#0C0C0C]">
            <h2 class="font-mono text-sm font-black tracking-[0.3em] uppercase mb-4 text-[#FAFAFA]">
              Bitácora
            </h2>
            <p class="text-zinc-500 text-sm leading-relaxed font-light mb-6">
              Notas, guías y aprendizajes esporádicos sobre desarrollo, diseño de sistemas y mi viaje constante en la industria tech.
            </p>
            <a href="/blog" class="inline-flex items-center text-[#d5338b] hover:text-white font-mono text-xs font-bold uppercase tracking-widest border-b-[1.5px] border-[#d5338b] hover:border-white pb-1 transition-all">
              Leer Blog →
            </a>
          </div>

          <div class="lg:col-span-3 flex flex-col divide-y-[1.5px] divide-white/10">
            {recentPosts.length > 0 ? (
              recentPosts.map(post => {
                const dateObj = new Date(post.data.pubDate);
                const day = String(dateObj.getDate()).padStart(2, '0');
                const month = MONTHS_ES[dateObj.getMonth()].toUpperCase();
                const year = dateObj.getFullYear();
                
                return (
                  <a href={`/blog/${post.id}/`} class="flex flex-col md:flex-row md:items-center p-6 md:p-8 hover:bg-white/[0.03] transition-colors group">
                    <div class="font-mono text-xs text-zinc-500 w-32 shrink-0 mb-3 md:mb-0 uppercase tracking-widest md:border-r-[1.5px] md:border-white/10 group-hover:text-zinc-300 transition-colors">
                      {day} {month} {year}
                    </div>
                    <div class="flex-1 md:pl-8">
                      <h3 class="text-lg md:text-xl font-bold text-zinc-100 group-hover:text-[#FAFF00] transition-colors mb-2">
                        {post.data.title}
                      </h3>
                      <p class="text-sm text-zinc-400 group-hover:text-zinc-300 transition-colors line-clamp-1">
                        {post.data.description}
                      </p>
                    </div>
                    <div class="hidden md:flex opacity-0 group-hover:opacity-100 -translate-x-4 group-hover:translate-x-0 transition-all ml-4">
                      <span class="text-[#FAFF00] font-bold text-xl">→</span>
                    </div>
                  </a>
                );
              })
            ) : (
              <div class="p-12 text-center bg-[#0A0A0A] font-mono text-xs text-zinc-600 uppercase tracking-widest">
                /* Ninguna nota publicada todavía */
              </div>
            )}
          </div>
        </section>

        {/* ── ZEEW SPACE CTA SECTION ── */}
        <section class="border-t-[1.5px] border-white/10 flex flex-col md:flex-row">
          <div class="p-8 md:p-12 lg:p-16 flex-1 bg-[#d5338b] text-[#FAFAFA] flex flex-col justify-center relative overflow-hidden group">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            
            <div class="mb-4 relative z-10">
              <span class="px-3 py-1 border-[1.5px] border-[#0A0A0A] text-[#0A0A0A] font-mono text-[10px] font-black uppercase tracking-widest bg-transparent">
                Aprende Conmigo ///
              </span>
            </div>
            
            <h2 class="text-4xl sm:text-5xl lg:text-7xl font-black tracking-tighter mb-6 text-[#0A0A0A] relative z-10 leading-[1.05]">
              ¿QUIERES APRENDER ALGO <br class="hidden xl:block"/>NUEVO HOY?
            </h2>
            
            <p class="text-lg md:text-xl font-medium leading-relaxed max-w-3xl mb-10 text-[#0A0A0A]/85 relative z-10">
              No hay mejor forma de aprender que construyendo proyectos del mundo real. Únete a la comunidad de Zeew Space y transforma la teoría abstracta en código de producción puro y duro.
            </p>
            
            <div class="relative z-10">
              <a href="https://zeew.space" target="_blank" class="inline-block w-max px-6 sm:px-8 py-4 sm:py-5 border-[1.5px] border-[#0A0A0A] bg-[#0A0A0A] text-white font-mono text-xs sm:text-sm font-black uppercase tracking-widest shadow-[6px_6px_0_0_rgba(10,10,10,0.5)] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0_0_rgba(10,10,10,0.8)] transition-all focus:outline-none">
                Unirme a Zeew Space ↗
              </a>
            </div>
          </div>
        </section>

        {/* <SponsorsGrid /> */}

      </main>

      {/* ── FOOTER ── */}
      <footer class="border-t-[1.5px] border-white/10 bg-[#111111]">
        {/* Massive Contact Block */}
        <div class="p-8 md:p-16 lg:p-24 flex flex-col items-center justify-center text-center border-b-[1.5px] border-white/10 group">
          <span class="font-mono text-xs text-zinc-500 uppercase tracking-[0.3em] mb-4">¿Tienes una idea en mente?</span>
          <a href="https://www.linkedin.com/in/kamerrezz/" target="_blank" class="text-4xl sm:text-6xl md:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-zinc-600 transition-transform hover:scale-105">
            HABLEMOS.
          </a>
        </div>
        
        {/* Real Footer Bar */}
        <div class="grid grid-cols-1 md:grid-cols-3 divide-y-[1.5px] md:divide-y-0 md:divide-x-[1.5px] divide-white/10 text-center">
          <div class="p-6 md:p-8 flex items-center justify-center gap-3">
            <span class="w-2.5 h-2.5 bg-green-500 shadow-[0_0_12px_#22c55e]"></span>
            <span class="font-mono text-[10px] sm:text-xs font-bold tracking-widest uppercase text-white">Disponible</span>
          </div>
          <div class="p-6 md:p-8 flex flex-wrap gap-4 items-center justify-center">
             <a href="https://github.com/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">GitHub</a>
             <span class="text-zinc-600">/</span>
             <a href="https://linkedin.com/in/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">LinkedIn</a>
             <span class="text-zinc-600">/</span>
             <a href="https://twitter.com/KamerrEzz" target="_blank" class="font-mono text-[10px] lg:text-xs font-bold tracking-widest uppercase text-zinc-400 hover:text-white transition-colors">Twitter</a>
